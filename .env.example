# ─────────────────────────────────────────────
#  CONFIGURAÇÕES DO BOT HYPER
#  Copie este arquivo para .env e preencha
#  Não é necessário e-mail/senha — o login é feito manualmente
# ─────────────────────────────────────────────

# URL da plataforma
HYPER_URL=https://conversas.hyperflow.global/chats

# Configurações fixas da conversa (não alterar)
DEPARTAMENTO=Negociação
CANAL=+55 81 9179-4459 - SER Educacional - Negociacao (Negociação)

# Caminho para a planilha de alunos
PLANILHA_PATH=data/filtro_alunos.xlsx

# Coluna da planilha com o telefone (ex: A, B, C...)
COLUNA_TELEFONE=A

# Coluna da planilha com o nome do aluno
COLUNA_NOME=B

# Coluna da matrícula na planilha
COLUNA_MATRICULA=C

# Linha onde começam os dados (pular cabeçalho)
LINHA_INICIO=2

# Delay entre ações (em segundos) — simula comportamento humano
DELAY_MIN=0.8
DELAY_MAX=2.0

# Tentativas em caso de falha por aluno
MAX_TENTATIVAS=3

# Rodar em modo visível (false = headless/sem abrir janela)
HEADLESS=false

# ── Navegador ────────────────────────────────────────
# Caminho do Chrome (deixe vazio para detecção automática)
CHROME_PATH=

# Porta de debug remoto do Chrome (padrão: 9222)
CHROME_DEBUG_PORT=9222
